# Monorepo environment reference
#
# Runtime configuration is split by app:
# - API worker vars and secrets: apps/api/.env.example
# - Web build-time vars: apps/web/.env.example

# Local frontend -> API wiring
VITE_API_URL=http://localhost:8787

# Local API vars mirrored from apps/api/wrangler.dev.toml
APP_ENV=development
PUBLIC_BASE_URL=http://localhost:5173
AUTH_URL=http://localhost:8787/auth

# Required before staging/production traffic
AUTH_SECRET=replace-with-a-long-random-secret
AUTH_ENCRYPTION_KEY=replace-with-a-long-random-secret

# Configure at least one Auth.js OAuth provider
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Recommended in staging/production
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=coderail-flow@1.0.0

# Optional billing integration
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_VARIANT_PRO=
LEMONSQUEEZY_VARIANT_TEAM=
