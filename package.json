{
  "name": "coderail-flow-starter",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --parallel --filter @coderail-flow/api --filter @coderail-flow/web run dev",
    "dev:api": "pnpm --filter @coderail-flow/api run dev",
    "dev:web": "pnpm --filter @coderail-flow/web run dev",
    "dev:runner": "tsx scripts/local-runner.ts",
    "build:web": "pnpm --filter @coderail-flow/web run build",
    "deploy:api": "npm --workspace apps/api run deploy",
    "deploy:web": "npm --workspace apps/web run deploy",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:web": "pnpm --filter @coderail-flow/web run test",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:all": "vitest run && playwright test",
    "lint": "eslint 'apps/**/src/**/*.{ts,tsx}' 'packages/**/src/**/*.{ts,tsx}' --max-warnings 0",
    "lint:fix": "eslint 'apps/**/src/**/*.{ts,tsx}' 'packages/**/src/**/*.{ts,tsx}' --fix",
    "format": "prettier --write 'apps/**/src/**/*.{ts,tsx}' 'packages/**/src/**/*.{ts,tsx}'",
    "format:check": "prettier --check 'apps/**/src/**/*.{ts,tsx}' 'packages/**/src/**/*.{ts,tsx}'",
    "perf:benchmark": "tsx scripts/perf-benchmark.ts",
    "security:verify": "tsx scripts/security-verify.ts",
    "security:pentest": "tsx scripts/pentest-smoke.ts",
    "validate:production": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm test && pnpm run test:web && pnpm run build:web",
    "deploy:production": "bash scripts/deploy-production.sh",
    "deploy:production:api": "cd apps/api && wrangler deploy --env=\"\"",
    "deploy:production:web": "cd apps/web && pnpm run build && wrangler pages deploy dist --project-name=coderail-flow --commit-dirty=true",
    "test:e2e:production": "bash scripts/run-e2e-production.sh"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260405.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "puppeteer": "^24.37.5",
    "tsx": "^4.21.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@sentry/cloudflare": "^10.42.0",
    "hono": "^4.11.10"
  }
}
