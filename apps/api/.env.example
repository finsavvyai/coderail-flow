# Set via apps/api/wrangler.toml [vars] or `wrangler secret put --cwd apps/api`
APP_ENV=production
PUBLIC_BASE_URL=https://coderail-flow.pages.dev
AUTH_URL=https://api.coderail.dev/auth

# Sentry error monitoring (optional - recommended in staging/production)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=coderail-flow@1.0.0

# Auth.js session signing (required in staging/production; readiness fails without it)
AUTH_SECRET=

# Configure at least one Auth.js OAuth provider (required in staging/production)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# Auth profile encryption (required in staging/production)
# Use a long random secret, e.g. openssl rand -base64 32
AUTH_ENCRYPTION_KEY=

# Integration config encryption (optional; falls back to AUTH_ENCRYPTION_KEY)
INTEGRATION_ENCRYPTION_KEY=
INTEGRATION_ENCRYPTION_KEY_ID=default
# Comma-separated key ring, format: keyId:secret,keyId2:secret2
INTEGRATION_ENCRYPTION_FALLBACK_KEYS=
# Optional Cloudflare KMS key names (requires CLOUDFLARE_KMS service binding)
INTEGRATION_ENCRYPTION_KMS_KEY_NAME=
# Comma-separated key names to allow old ciphertext decryption during key rotation
INTEGRATION_ENCRYPTION_KMS_FALLBACK_KEY_NAMES=
# Optional bearer token for KMS service authentication
CLOUDFLARE_KMS_AUTH_TOKEN=

# Compliance / retention policy default (days)
DATA_RETENTION_DAYS=90

# SSO (optional, Task 15 baseline)
SSO_GOOGLE_CLIENT_ID=
SSO_GITHUB_CLIENT_ID=
SSO_SAML_ENTRYPOINT=
SSO_SAML_CERT=

# Lemon Squeezy billing (optional – billing routes disabled without these)
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_VARIANT_PRO=
LEMONSQUEEZY_VARIANT_TEAM=
