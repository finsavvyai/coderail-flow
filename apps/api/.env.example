# Set via wrangler.toml [vars] or `wrangler secret put`
APP_ENV=production
PUBLIC_BASE_URL=https://coderail-flow.pages.dev

# Clerk auth (optional – auth middleware skipped without this)
# Value is your Clerk Frontend API URL, e.g. https://clerk.your-domain.dev
CLERK_ISSUER=

# Lemon Squeezy billing (optional – billing routes disabled without these)
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_VARIANT_PRO=
LEMONSQUEEZY_VARIANT_TEAM=
