# Required in staging/production
VITE_API_URL=https://api.your-domain.dev

# Required in staging/production for protected routes
VITE_CLERK_PUBLISHABLE_KEY=pk_live_...

# Local `pnpm run dev` may omit VITE_CLERK_PUBLISHABLE_KEY and use the unauthenticated dev shell.

# Optional for local-only "Local Browser" recorder mode (`pnpm dev:runner`)
VITE_RUNNER_URL=http://localhost:8788
